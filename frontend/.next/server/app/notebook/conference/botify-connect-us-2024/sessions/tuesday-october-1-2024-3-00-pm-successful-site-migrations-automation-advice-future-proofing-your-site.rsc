0:["MpVcO4C87JgkEYB9B8VrV",[[["",{"children":["notebook",{"children":["conference",{"children":[["slug","botify-connect-us-2024","d"],{"children":["sessions",{"children":[["sessionId","tuesday-october-1-2024-3-00-pm-successful-site-migrations-automation-advice-future-proofing-your-site","d"],{"children":["__PAGE__?{\"slug\":\"botify-connect-us-2024\",\"sessionId\":\"tuesday-october-1-2024-3-00-pm-successful-site-migrations-automation-advice-future-proofing-your-site\"}",{}]}]}]}]}]}]},"$undefined","$undefined",true],["",{"children":["notebook",{"children":["conference",{"children":[["slug","botify-connect-us-2024","d"],{"children":["sessions",{"children":[["sessionId","tuesday-october-1-2024-3-00-pm-successful-site-migrations-automation-advice-future-proofing-your-site","d"],{"children":["__PAGE__",{},[["$L1",["$","$L2",null,{"ctx":{"conference":{"slug":"botify-connect-us-2024","name":"Botify Connect US","edition":"2024","year":2024,"status":"attended","startDate":"2024-10-01","endDate":"2024-10-01","dateLabel":"October 2024","city":"Austin","country":"USA","url":"https://www.botify.com/connect","organizer":"Botify","topic":"Generative AI, search, and the future of organic discovery — through Botify's enterprise-SEO lens.","summary":"An invite-only one-day enterprise SEO summit in Austin, TX. Eleven sessions across the AI/search stack: from PhD-level reasoning models, to RAG, to AI Overviews, to migrations and the C-suite conversation. Attended in person — these are my notes.","speakerCount":28,"hoursOfTalks":8,"venues":[{"name":"Austin, Texas","city":"Austin","country":"USA"}],"days":[{"date":"Tuesday, October 1, 2024","theme":"Connect US 2024","themeSummary":"Eleven back-to-back sessions on generative AI, search, customer experience, migrations, and the C-suite conversation. The through-line: act now, automate everything, and stop optimizing for keywords.","sessions":[{"start":"9:00 AM","end":"9:45 AM","type":"keynote","title":"From Evolution to Revolution: The Role of Generative AI in Life & Search","speaker":"A.J. Ghergich","affiliation":"VP Consulting Services, Botify","speakerUrl":"https://www.linkedin.com/in/ajghergich/","description":"We've leapt to Level 4 PhD-reasoning AI faster than the industry predicted. Brands that wait will be steamrolled — empowerment over doom.","takeaways":["Act now — inaction is the real risk","Customer intent hasn't changed; only the interfaces did","AI is happening because of us — we direct it"]},{"start":"9:45 AM","end":"10:15 AM","type":"talk","title":"Traditional vs Gen AI Search: Everything You Need to Know","speaker":"Dalton Finney","affiliation":"Solutions Engineer, Botify","speakerUrl":"https://www.linkedin.com/in/dalton-finney/","description":"Bing's index quietly powers ChatGPT and Copilot. Optimize for it. RAG closes the freshness gap; structured data is the entry fee.","takeaways":["Bing's index = the new SEO surface (powers ChatGPT + Copilot)","RAG = LLM + live search index for real-time answers","Structured data + content automation are non-negotiable"]},{"start":"10:15 AM","end":"11:00 AM","type":"panel","title":"The Inside Perspective on Modern Search","speaker":"Fabrice Canel","affiliation":"Principal Product Manager, Bing","speakerUrl":"https://www.linkedin.com/in/fabricecanel/","description":"Inside view from Bing on how AI rewrites search engines. Co-paneled with Adrien Ménard (Botify).","takeaways":["Conversational queries replace fragmented keyword strings","Crawlability + structured data still decide who AI cites","Automate content freshness — sitemaps, IndexNow, APIs"]},{"start":"11:00 AM","end":"11:45 AM","type":"panel","title":"Speed Ahead to Stay Ahead: Brand Success Strategies & the Power of Automation","speaker":"Anthony Cantelmo","affiliation":"Director, Search & Content, Discount Tire","speakerUrl":"https://www.linkedin.com/in/anthonycantelmo/","description":"Panel with Rick Egan (Beyond), Cody Exter (Botify), Federico Rodriguez (Best Buy), Cody Walker (Maui Jim), Adrien Ménard (Botify). Real-world automation case studies.","takeaways":["Indexation: 6-month crawl → 60 days with dynamic XML sitemaps","AI-written page titles lifted CTR (Best Buy)","Suppress paid ads when organic owns the SERP"]},{"start":"11:45 AM","end":"12:30 PM","type":"talk","title":"Protect Today's Progress & Prepare for Tomorrow with Botify","speaker":"Christophe Frenet","affiliation":"VP Product, Botify","speakerUrl":"https://www.linkedin.com/in/christophe-frenet/","description":"Co-presented with Rebecca Zabow. Bot-traffic intelligence: measure what AI bots actually consume, then push the right content to the right index.","takeaways":["Track which AI bots hit your site + how often","Push content directly to AI indexes (don't wait to be crawled)","AI-generated titles + A/B test before full rollout"]},{"start":"1:30 PM","end":"2:15 PM","type":"panel","title":"Beyond Search: How Customer Experience Is Adapting","speaker":"Greg Coleman","affiliation":"Chief Strategy Officer","speakerUrl":"https://www.linkedin.com/in/gregwcoleman/","description":"With Lauri Joffe (American Freight) + Noam Paransky (Tapestry). Gen Z's search behavior is bifurcating — social/visual win the brand-discovery moment.","takeaways":["Gen Z: only 64% use traditional search (vs 94% older)","Visual search + TikTok = brand discovery for younger cohorts","Four-part exec framework: cost · revenue · enabling tech · fear"]},{"start":"2:15 PM","end":"3:00 PM","type":"panel","title":"The Power of Organic: How Organizations Use Search as a Strength","speaker":"Charley Hackerson","affiliation":"Senior Director, Customer Strategy, Botify","speakerUrl":"https://www.linkedin.com/in/charleyhackerson/","description":"With Jason Mandragona (NBCU News) + Abishek Surana Rajendra (Course Hero). Building cross-functional SEO culture + in-house A/B testing.","takeaways":["In-house SEO A/B testing platform → exec credibility","Quality-scored content beats volume","Educate other teams — distribute SEO ownership"]},{"start":"3:00 PM","end":"3:45 PM","type":"panel","title":"Successful Site Migrations: Automation, Advice, & Future-Proofing Your Site","speaker":"Zach Chahalis","affiliation":"SEO Lead, Apartments.com","speakerUrl":"https://www.linkedin.com/in/zacharychahalis/","description":"With Jordan Long (Botify), Dave Marks (Recurrent), Sharanya Srinivasan (Care.com), Cody Walker (Maui Jim), Adrien Ménard (Botify). Migration war stories.","takeaways":["Bring SEO in on day one — not at QA","Automation handles the boring 90% of QA","Comprehensive checklists are not optional"]},{"start":"3:45 PM","end":"4:30 PM","type":"panel","title":"Uniting Search, SEOs, & the C-Suite","speaker":"Krista Dalton","affiliation":"Director of SEO, Tecovas","speakerUrl":"https://www.linkedin.com/in/kristadalton/","description":"With Chris Long (GoFish), Praneet Nigam (Signet), Jacque Urick (Realtor.com), Cody Walker (Maui Jim), Adrien Ménard. How to talk to executives about SEO.","takeaways":["Translate SEO into customer-experience metaphors","SEO is not free — surface the real investment","Pre-empt the AI question, don't dodge it"]},{"start":"4:30 PM","end":"5:00 PM","type":"talk","title":"How Google's AI Overviews Are Changing Consumer Behaviors","speaker":"Ray Grieselhuber","affiliation":"Founder & CEO, DemandSphere","speakerUrl":"https://www.linkedin.com/in/raygrieselhuber/","description":"With Tim Resnik (Botify) + Abishek Surana Rajendra (Course Hero). New SERP metrics: pixel depth, visual rankings, cosine similarity.","takeaways":["75% of AI Overview links come from top-12 organic","Track pixel depth, not just rank","Long-tail informational queries drive AIO frequency"]},{"start":"5:00 PM","end":"5:45 PM","type":"keynote","title":"Predictions for Search & How to Prepare Today","speaker":"A.J. Ghergich","affiliation":"VP Consulting Services, Botify","speakerUrl":"https://www.linkedin.com/in/ajghergich/","description":"Closing keynote with Adrien Ménard, Abishek Surana Rajendra, Frank Vitovitch (Botify). Bold predictions: AGI, AI bot traffic governance, the death of keyword-driven SEO.","takeaways":["Share of voice + brand mentions > keyword rankings","AI bots will outnumber human visitors — govern accordingly","AGI is closer than the industry admits"]}]}]},"session":"$3","sessionId":"tuesday-october-1-2024-3-00-pm-successful-site-migrations-automation-advice-future-proofing-your-site","dayDate":"Tuesday, October 1, 2024","dayIndex":0,"dayTheme":"Connect US 2024","prev":{"sessionId":"tuesday-october-1-2024-2-15-pm-the-power-of-organic-how-organizations-use-search-as-a-strength","title":"The Power of Organic: How Organizations Use Search as a Strength","start":"2:15 PM"},"next":{"sessionId":"tuesday-october-1-2024-3-45-pm-uniting-search-seos-the-c-suite","title":"Uniting Search, SEOs, & the C-Suite","start":"3:45 PM"}}}],null],null],null]},[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","notebook","children","conference","children","$6","children","sessions","children","$7","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","notebook","children","conference","children","$6","children","sessions","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","notebook","children","conference","children","$6","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","n