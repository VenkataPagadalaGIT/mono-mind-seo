3:{"start":"11:15 AM","end":"11:45 AM","type":"talk","title":"Watch the Party Die: Engineering 'Answerability' for Prospective Students","speaker":"Ray Martinez","affiliation":"VP of SEO, Archer Education","speakerUrl":"https://www.linkedin.com/in/raymond-martinez-seo/","description":"Archer's playbook for AI Web Search + LLM Fetch. Student-first knowledge graph with custom schema, entity gap analysis, semantic scoring."}
