0:["A-HjrGIWPt9F8ayX_dX6l",[[["",{"children":["notebook",{"children":["conference",{"children":[["slug","tech-seo-connect-2024","d"],{"children":["sessions",{"children":[["sessionId","friday-october-18-2024-10-30-pm-the-state-of-technical-seo-in-2024","d"],{"children":["__PAGE__?{\"slug\":\"tech-seo-connect-2024\",\"sessionId\":\"friday-october-18-2024-10-30-pm-the-state-of-technical-seo-in-2024\"}",{}]}]}]}]}]}]},"$undefined","$undefined",true],["",{"children":["notebook",{"children":["conference",{"children":[["slug","tech-seo-connect-2024","d"],{"children":["sessions",{"children":[["sessionId","friday-october-18-2024-10-30-pm-the-state-of-technical-seo-in-2024","d"],{"children":["__PAGE__",{},[["$L1",["$","$L2",null,{"ctx":{"conference":{"slug":"tech-seo-connect-2024","name":"Tech SEO Connect","edition":"2024","year":2024,"status":"attended","startDate":"2024-10-18","endDate":"2024-10-18","dateLabel":"October 18, 2024","city":"Raleigh","country":"USA","url":"https://www.techseoconnect.com/","organizer":"Tech SEO Connect","topic":"Pure technical SEO — automation, embeddings, Core Web Vitals, and AI-era search infrastructure.","summary":"A one-day deep-dive into technical SEO in Raleigh, NC. Sixteen sessions on Core Web Vitals, embeddings & vector search, GSC limits, BigQuery pipelines, machine-learning workflows, and how to actually ship technical recommendations inside large orgs. Attended in person — these are my notes.","speakerCount":16,"hoursOfTalks":8,"venues":[{"name":"Raleigh, North Carolina","city":"Raleigh","country":"USA"}],"days":[{"date":"Friday, October 18, 2024","theme":"Tech SEO Connect 2024","themeSummary":"Sixteen back-to-back technical SEO talks: Core Web Vitals, embeddings, BERT vs Word2Vec, BigQuery for SEOs, GSC bulk export, automation pipelines, and the perennial human problem — getting recommendations actually shipped.","sessions":[{"start":"9:00 AM","end":"9:45 AM","type":"keynote","title":"Optimizing Core Web Vitals","speaker":"Rick Viscomi","affiliation":"Core Web Vitals DevRel, Google","speakerUrl":"https://www.linkedin.com/in/rviscomi/","description":"Rick on the FID→INP transition (mobile pass rate jumped 65%→76%), and the practical playbook: prioritize critical resources, leverage BFCache, set CSS aspect-ratios for CLS, break long JS tasks, adopt RUM not Lab.","takeaways":["INP launched successfully — community awareness drove 11pt mobile pass-rate lift","Make LCP discoverable — no background-image hero, no loading=lazy, use fetchpriority=high","CLS fix: aspect-ratio CSS + BFCache for instant nav","RUM > Lab data for diagnosing real INP problems"]},{"start":"9:45 AM","end":"10:30 AM","type":"talk","title":"NPath: Leveraging LLMs to Extract Insights from GA4 Event Data","speaker":"JR Oakes","affiliation":"VP of Strategy, LOCOMOTIVE Agency","speakerUrl":"https://www.linkedin.com/in/jr-oakes-3660546/","description":"Empath + NPath: open-source pipelines that crawl GA4 + GSC + PageSpeed at intervals, feed data into LLMs, and email alerts on significant pattern shifts.","takeaways":["LLMs with M-token context can extract hidden patterns from event sequences","Empath uses genetic-algorithm sequence analysis on GA4 events","NPath = open-source automated alerts for traffic / next-page / performance drops"]},{"start":"10:30 AM","end":"11:15 AM","type":"talk","title":"Getting Technical SEO Work Done at Fortune 100 Companies","speaker":"Kevin Indig","affiliation":"Growth Advisor, Hims · Dropbox · Reddit","speakerUrl":"https://www.linkedin.com/in/kevinindig/","description":"The SEO 'Ship Show': <50% of recommendations get implemented. The fix isn't more data — it's story-based pitching, three-priority focus, and explicit risk framing.","takeaways":["Story > data — execs decide on instinct + emotion","3 priorities per pitch, not 30","Deep recommendations with subtasks beat shallow 'fix indexation' notes","Lead with risk, not reward — what happens if we DON'T do this","Back-channel before the big meeting — use their wording"]},{"start":"11:15 AM","end":"12:00 PM","type":"talk","title":"Gaining Velocity: Building SEO into a Continuous Development Process","speaker":"Rachel Anderson","affiliation":"Senior SEO Manager, Weedmaps","speakerUrl":"https://www.linkedin.com/in/rachel-anderson-a5b0a460/","description":"Reactive SEO firefighting → proactive 4-prong fix: automated SEO tests in CI/CD, SEO sign-off on PRDs, JIRA tag-gating high-risk tickets, engineering education. Result: high-impact regression bugs cut in half.","takeaways":["Automate SEO checks inside the CI/CD pipeline (canonical, H1, hreflang)","Add Googlebot user stories + acceptance criteria to every PRD","JIRA tag → SEO QA review → blocks deploy if skipped","Educate engineers on crawl/render/index — make SEO their concern too"]},{"start":"12:00 PM","end":"12:45 PM","type":"talk","title":"Improving SEO in Cloud Environments","speaker":"Fili Wiese","affiliation":"SEO Consultant · Ex-Google Engineer","speakerUrl":"https://www.linkedin.com/in/filiwiese/","description":"60% of the web is duplicate content — and cloud environments make it worse. Staging subdomains, CDN canonicals, serverless cold starts, and load-balancer URLs all leak into the index.","takeaways":["Treat URLs like immutable database row IDs — never change them casually","Audit hostnames + subdomains regularly — Walmart staging was indexed","Log full URLs with protocols + subdomain — partial logs lie","Cloud Run / serverless: hard-code canonicals to defeat load-balancer leakage","Optimize TTFB + warm instances — cold starts hurt rankings"]},{"start":"12:45 PM","end":"1:30 PM","type":"meal","title":"Lunch"},{"start":"1:30 PM","end":"2:15 PM","type":"talk","title":"Rolling Your Own Rank Tracking Solution","speaker":"Paul Shapiro","affiliation":"Web Intelligence, Uber","speakerUrl":"https://www.linkedin.com/in/paulnshapiro/","description":"Built Rank and Berry — open-source rank tracker on Python+FastAPI+Vue+SQLite. Why? Most platforms silo data and lock you out of customization.","takeaways":["Open-source rank tracker = full data control + customization","Backend Python+FastAPI, frontend Vue, SQLite for dev → Postgres for prod","Estimate Business Impact field — GSC CTR × your conversion rate × AOV","Roadmap: anomaly detection, algo update overlays, keyword clustering"]},{"start":"2:15 PM","end":"3:00 PM","type":"talk","title":"Chasing the Googlebot Trail","speaker":"Jori Ford","affiliation":"CMO, FoodBoss","speakerUrl":"https://www.linkedin.com/in/chicagoseopro","description":"Crawling is the most underestimated lever in SEO. GSC's crawl stats only tell part of the story — heat-map Googlebot's entry points and identify dead zones.","takeaways":["Crawl total ≠ better — depends on site size and goals","Use DOM Content Load as response-time proxy (server-side metrics lie)","Heat-map Googlebot entry points to find content hubs vs dead zones","Auto-download crawl data with Apps Script + ChatGPT","GSC Host Status only flags after 90 days — too late"]},{"start":"3:00 PM","end":"3:45 PM","type":"talk","title":"When is Cloaking a Good Idea?","speaker":"Victor Pan","affiliation":"Principal SEO, HubSpot","speakerUrl":"https://www.linkedin.com/in/victorpan/","description":"Cloaking isn't binary evil — strategic bot-side cloaking can save server load, fix GDPR-driven attribution, and improve Core Web Vitals without misleading users.","takeaways":["Block Googlebot from non-rendering JS (heatmaps, ad pixels) — saves crawl budget","Edge-compute different image sizes by device — bots get the canonical","GDPR consent + analytics: cloak parameter rewrite from Googlebot","Don't mislead users — same essential content for both"]},{"start":"3:45 PM","end":"4:30 PM","type":"talk","title":"Microsoft Bing — SEO for the AI Era","speaker":"Fabrice Canel","affiliation":"Bing Product Manager, Microsoft","speakerUrl":"https://www.linkedin.com/in/fabricecanel/","description":"AI doesn't kill SEO — it diversifies it. Bing's index now powers ChatGPT, Perplexity, Yahoo, Meta. New Webmaster Tools Copilot, 16-month performance data, Deep Search.","takeaways":["AI clicks convert better than search clicks — track conversions not just clicks","IndexNow protocol = push updates instead of waiting to be crawled","Bing Webmaster Tools Copilot gives personalized SEO recommendations","Performance report extended to 16 months including AI-experience traffic"]},{"start":"4:30 PM","end":"5:15 PM","type":"talk","title":"How to Incorporate Machine Learning Into Your SEO Day-to-Day","speaker":"Lazarina Stoy","affiliation":"Founder, MLOpsSEO","speakerUrl":"https://www.linkedin.com/in/lazarinastoy/","description":"Practical ML for SEOs: text classification, keyword clustering, fuzzy matching, content moderation, transcription. Why fine-tuned models beat ChatGPT on precision tasks.","takeaways":["Supervised (regression/classification) for consistency — unsupervised (clustering) for exploration","Google NLP API > ChatGPT for entity extraction + classification (precision scores)","BERTopic > LDA for big-site topic clustering","Don't aim for perfection — aim for automation + human oversight"]},{"start":"5:15 PM","end":"6:00 PM","type":"talk","title":"Automating Marketing Tasks With AI","speaker":"Kristin Tynski","affiliation":"Co-Founder & SVP Creative, Fractl","speakerUrl":"https://www.linkedin.com/in/kristintynski/","description":"Content cost is heading to zero — value is unique data + journalism. Agentic frameworks, RAG, retrieval-augmented generation, and 25 automation scripts you can run today.","takeaways":["Future SEO standard = data journalism at scale, not generic AI content","RAG fixes hallucinations — ground the LLM in your sources of truth","One-input-many-outputs: blog → social posts → newsletter → product copy","Decreased organic traffic is real — adapt with original data + multimedia"]},{"start":"6:00 PM","end":"6:45 PM","type":"keynote","title":"Accounting for Gaps in SEO Software","speaker":"Michael King","affiliation":"Founder & CEO, iPullRank","speakerUrl":"https://www.linkedin.com/in/michaelkingphilly/","description":"Most SEO tools are stuck on TF-IDF and 'compare to top 20 pages.' Google moved to vector embeddings + dense retrieval years ago. The mismatch is why your tools lie.","takeaways":["Google uses site-level + author-level embeddings to score relevance holistically","Information Gain — how much NEW info your page adds vs the rest of the SERP","Hybrid retrieval: lexical + semantic = pages rank without keywords in title","DOJ leak confirmed click metrics influence rank — last longest click matters","Open-source SEO data initiative coming via Search Telemetry Project"]},{"start":"6:45 PM","end":"7:30 PM","type":"talk","title":"The Shift in Search Engines to Answer Engines","speaker":"Dan Hinckley","affiliation":"CTO & Co-Founder, Go Fish Digital","speakerUrl":"https://www.linkedin.com/in/danielhinckley/","description":"Built Barracuda — an internal tool that scrapes competitors, embeds the data, and generates SEO insights. 4-hour audits → 4 minutes.","takeaways":["Vector embeddings DB = give LLMs accurate, retrievable grounding","Function calls fix LLM math/counting failures — let it call a calculator","Tell the model 'say I don't know' — error rates drop dramatically","Barracuda automates content gap, internal linking, alt text, topical authority"]},{"start":"7:30 PM","end":"8:15 PM","type":"talk","title":"AI + Me: How We Built a GSC Bulk Export Data Pipeline","speaker":"Noah Learner","affiliation":"Director of Innovation, Sterling Sky","speakerUrl":"https://www.linkedin.com/in/noahlearner/","description":"Built Branch Explorer + GSC Bulk Export pipeline using only AI (ChatGPT/Claude). The lessons learned about what AI does well and where it fails.","takeaways":["GSC Bulk Export = no row limits, full anonymized queries + search appearances","No backfill — start the export immediately if you ever might want the data","Custom GPTs for specific stacks (Cloud, WordPress, Apps Script) speed coding","AI fails on debugging cycles — be ready to take over manually"]},{"start":"8:15 PM","end":"9:00 PM","type":"talk","title":"Can GSC Be the Source of SEO Decisions?","speaker":"Serge Bezborodov","affiliation":"CTO, JetOctopus","speakerUrl":"https://www.linkedin.com/in/sergebezborodov/","description":"Forensic teardown of GSC's data accuracy. Aggregation type, anonymized longtail, and mobile/desktop mismatches make GSC unreliable as a sole truth source.","takeaways":["GSC interface caps at thousands of rows — API is mandatory for big sites","Aggregation by property vs page returns different impressions/clicks","Anonymized longtail queries can hide most of your traffic potential","Add subfolders as GSC properties — one client went 80K → 4M tracked pages","Cross-verify GSC with crawler + log files — never trust one source"]},{"start":"9:00 PM","end":"9:45 PM","type":"talk","title":"BigQuery for SEOs","speaker":"Sam Torres","affiliation":"Chief Digital Officer, Gray Dot Company","speakerUrl":"https://www.linkedin.com/in/samantha-torres-seo/","description":"BigQuery solves GSC's 16-month limit and Looker Studio sampling problem — at $10/month for most clients. Build aggregate tables, schedule them daily, connect Looker to those.","takeaways":["10 GB free storage + 1 TB free queries/month = most clients pay <$10/mo","GSC site-level vs URL-level tables → different aggregation grains","Aggregate tables (pre-processed daily) save Looker Studio costs","Scheduled queries auto-refresh aggregates — connect dashboards there","Start small with the basic SELECT/FROM/WHERE/ORDER BY pattern"]},{"start":"9:45 PM","end":"10:30 PM","type":"talk","title":"What I Learned From Auditing Over 1,000,000 Websites","speaker":"Patrick Stox","affiliation":"Product Advisor, Ahrefs","speakerUrl":"https://www.linkedin.com/in/patrickstox/","description":"Most flagged 'issues' don't matter. Use impact-effort matrices, automate everything, embrace Edge SEO. Audit findings by ROI, not by checklist completionism.","takeaways":["Broken page with no traffic + no links = don't fix it","Multiple H1s, redirect chains under 5 hops, duplicate content = usually fine","60% of the web is duplicate content — Google handles canonicalization well","Hreflang misconfig cost one e-commerce client $6.5M/day — DO check that","AI scripts that took 12-14h now take 45 min — embrace automation + Edge SEO"]},{"start":"10:30 PM","end":"11:15 PM","type":"keynote","title":"The State of Technical SEO in 2024","speaker":"Aleyda Solis","affiliation":"Founder & International SEO Consultant, Orainti","speakerUrl":"https://www.linkedin.com/in/aleyda/","description":"Closing keynote. Where the discipline is heading: human factors still beat tooling, automation is now table-stakes, and the gap between recommendation and implementation remains the #1 blocker.","takeaways":["40-60% of technical recommendations get implemented — that's the bottleneck","Tools have caught up; humans haven't","Forecasting + RICE prioritization to win exec buy-in","Tailored reports per stakeholder — not one-size-fits-all audits"]}]}]},"session":"$3","sessionId":"friday-october-18-2024-10-30-pm-the-state-of-technical-seo-in-2024","dayDate":"Friday, October 18, 2024","dayIndex":0,"dayTheme":"Tech SEO Connect 2024","prev":{"sessionId":"friday-october-18-2024-9-45-pm-what-i-learned-from-auditing-over-1-000-000-websites","title":"What I Learned From Auditing Over 1,000,000 Websites","start":"9:45 PM"},"next":"$undefined"}}],null],null],null]},[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","notebook","children","conference","children","$6","children","sessions","children","$7","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L5",null,{"parallelRouterKey":"child